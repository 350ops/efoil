# ===========================================
# eFoil Maldives - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ===========================================
# STRIPE (Required for payments)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys

# Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret (starts with whsec_)
# Get this when you create a webhook endpoint at https://dashboard.stripe.com/webhooks
# For local testing, use: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# SITE CONFIGURATION (Required)
# ===========================================
# Your production domain (used for Stripe success/cancel URLs)
NEXT_PUBLIC_SITE_URL=https://efoil.rent

# ===========================================
# RESEND (Required for lead forms)
# ===========================================
# Get your API key from https://resend.com/api-keys
# You must also verify your domain (efoil.rent) at https://resend.com/domains
RESEND_API_KEY=re_your_api_key_here

# ===========================================
# NOTIFICATIONS
# ===========================================
# Email address that receives lead form submissions and booking notifications
NOTIFICATION_EMAIL=hello@efoil.rent

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# Password for protected pages/routes (if using route protection)
# ===========================================
# AUTH (Google OAuth)
# ===========================================
# Get these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_google_client_id_here
