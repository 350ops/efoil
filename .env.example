# ===========================================
# eFoil Maldives - Environment Variables
# ===========================================
# Copy this file to .env.local and fill in your values
# cp .env.example .env.local

# ===========================================
# STRIPE (Required for payments)
# ===========================================
# Get these from https://dashboard.stripe.com/apikeys

# Stripe Secret Key (starts with sk_test_ or sk_live_)
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Stripe Publishable Key (starts with pk_test_ or pk_live_)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here

# Stripe Webhook Secret (starts with whsec_)
# Get this when you create a webhook endpoint at https://dashboard.stripe.com/webhooks
# For local testing, use: stripe listen --forward-to localhost:3000/api/webhook
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ===========================================
# SITE CONFIGURATION (Required)
# ===========================================
# Your production domain (used for Stripe success/cancel URLs)
NEXT_PUBLIC_SITE_URL=https://efoil.rent

# ===========================================
# CONTACT / WHATSAPP (Required for booking links)
# ===========================================
# WhatsApp number for booking links (NEXT_PUBLIC_ prefix required for client-side access)
# Format: country code + number without + sign (e.g., 9606783344 for Maldives)
NEXT_PUBLIC_WHATSAPP_NUMBER=9606783344

# ===========================================
# OPTIONAL SETTINGS
# ===========================================
# Email for booking notifications (if you implement email notifications)
NOTIFICATION_EMAIL=hello@efoil.rent

# Password for protected pages/routes (if using route protection)
PAGE_ACCESS_PASSWORD=your_password_here
